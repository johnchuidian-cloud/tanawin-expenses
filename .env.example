# Copy to .env (public client config) and .env.local (server-only secrets).
# Both are gitignored. Real values are never committed.

# --- .env (shipped to the browser; safe to be public by design) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Run the app on a self-contained fictional dataset (no backend needed).
# Leave unset for normal operation; set to 1 for demos/screenshots.
# NEXT_PUBLIC_DEMO=1

# --- .env.local (server-only; never exposed to the browser) ---
# Service-role key, used only by scripts/import-to-supabase.js.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
